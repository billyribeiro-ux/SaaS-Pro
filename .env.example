# Copy to `.env` locally. On Vercel: Project → Settings → Environment Variables — add the same keys for Production (and Preview if needed).

# Supabase
PUBLIC_SUPABASE_URL=your_supabase_project_url
PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# App
PUBLIC_APP_URL=http://localhost:5173
PUBLIC_APP_NAME=SaaS-Pro

# Admin allowlist (comma-separated emails). New sign-ups whose email is in
# this list are auto-promoted to admin via the `handle_new_user` trigger.
# To promote an already-existing user, run:
#   select promote_user_to_admin('email@example.com');
# (run from Supabase SQL editor, with the service role key)
ADMIN_EMAILS=
