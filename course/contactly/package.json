{
	"name": "contactly",
	"description": "Contactly — the contact-management SaaS built lesson by lesson in the SaaS-Pro course.",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"engines": {
		"node": ">=20",
		"pnpm": ">=10"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test": "pnpm run test:unit -- --run && pnpm run test:e2e",
		"test:unit": "vitest",
		"test:e2e": "playwright test",
		"db:start": "supabase start",
		"db:stop": "supabase stop",
		"db:status": "supabase status",
		"db:reset": "supabase db reset",
		"db:push": "supabase db push",
		"db:diff": "supabase db diff -f",
		"db:migration:new": "supabase migration new",
		"types:generate": "supabase gen types typescript --local --schema public > src/lib/database.types.ts",
		"seed:contacts": "tsx scripts/seed-contacts.ts",
		"stripe:listen": "stripe listen --forward-to http://localhost:5173/api/webhooks/stripe",
		"stripe:trigger": "stripe trigger",
		"stripe:fixtures": "stripe fixtures stripe/fixtures/products.json",
		"stripe:cleanup": "tsx scripts/stripe-cleanup.ts",
		"stripe:dev": "tsx scripts/stripe-dev.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@faker-js/faker": "^10.4.0",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-auto": "^6.1.0",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.3",
		"dotenv": "^17.4.2",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"pino-pretty": "^13.1.3",
		"playwright": "^1.59.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"supabase": "^2.89.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"vitest-browser-svelte": "^2.1.0"
	},
	"dependencies": {
		"@sentry/sveltekit": "^10.49.0",
		"@supabase/ssr": "^0.10.2",
		"@supabase/supabase-js": "^2.103.3",
		"clsx": "^2.1.1",
		"pino": "^10.3.1",
		"stripe": "^22.0.2",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.3.6"
	}
}
