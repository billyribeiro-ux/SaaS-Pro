# Contactly — environment variables.
#
# Copy to `.env` for local development. `.env` is gitignored.
# In production these get set in the Vercel project settings.

# === Supabase (local) =================================================
# These are the static, well-known anon + URL values that
# `supabase start` prints. They're identical on every machine, so it's
# safe to commit them as the local default. Real, secret keys never
# live in this file.
PUBLIC_SUPABASE_URL="http://127.0.0.1:64321"
PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0"

# === Supabase (server-only) ===========================================
# The service-role key bypasses Row Level Security. Server code only.
# `supabase status` prints the local value.
SUPABASE_SERVICE_ROLE_KEY=""

# === Stripe (Module 6+) ===============================================
# - STRIPE_SECRET_KEY: prefer a Restricted API Key (`rk_test_...`)
#   from https://dashboard.stripe.com/test/apikeys with the minimum
#   scopes Contactly needs. See docs/stripe/07-stripe-node-client.md.
# - STRIPE_WEBHOOK_SECRET: copy the `whsec_...` value the Stripe CLI
#   prints when you run `pnpm run stripe:listen`. It rotates per
#   listener session in test mode.
# - PUBLIC_STRIPE_PUBLISHABLE_KEY: needed in Module 9 (Checkout
#   Element redirect helpers); leave blank until then.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# === Resend (Module 3 / 9) ============================================
# Used both by Supabase Auth (via SMTP) and by the app for transactional
# emails. https://resend.com/api-keys
RESEND_API_KEY=""

# === Sentry =========================================================
# - PUBLIC_SENTRY_DSN (Module 10.2): write-only ingestion url
#   ("public" by design). Empty = Sentry runtime disabled.
# - SENTRY_AUTH_TOKEN, SENTRY_ORG, SENTRY_PROJECT (Module 11.2):
#   build-time only. Drive source-map upload via @sentry/vite-plugin.
#   All three required together; empty = upload skipped, build
#   continues unchanged. Generate a token at:
#   https://<your-org>.sentry.io/settings/auth-tokens/
#   Required scopes: project:write, release:admin.
# - PUBLIC_SENTRY_RELEASE (Module 11.3): explicit release override.
#   Falls back to VERCEL_GIT_COMMIT_SHA, then 'dev'.
PUBLIC_SENTRY_DSN=""
PUBLIC_SENTRY_RELEASE=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# === Operator API token (Module 10.3) =================================
# When set, monitoring tools (UptimeRobot, Datadog Synthetics, …) can
# hit /api/admin/* endpoints with `Authorization: Bearer <token>`
# instead of going through the human auth + is_platform_admin cookie
# path. Generate with:
#
#   node -e "console.log(crypto.randomBytes(32).toString('base64url'))"
#
# Empty disables the bearer branch entirely (no token is accepted).
OPS_API_TOKEN=""
