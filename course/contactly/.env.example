# Contactly — environment variables.
#
# Copy to `.env` for local development. `.env` is gitignored.
# In production these get set in the Vercel project settings.

# === Supabase (local) =================================================
# These are the static, well-known anon + URL values that
# `supabase start` prints. They're identical on every machine, so it's
# safe to commit them as the local default. Real, secret keys never
# live in this file.
PUBLIC_SUPABASE_URL="http://127.0.0.1:64321"
PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0"

# === Supabase (server-only) ===========================================
# The service-role key bypasses Row Level Security. Server code only.
# `supabase status` prints the local value.
SUPABASE_SERVICE_ROLE_KEY=""

# === Stripe (Module 5+) ===============================================
# Test-mode keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# === Resend (Module 3 / 9) ============================================
# Used both by Supabase Auth (via SMTP) and by the app for transactional
# emails. https://resend.com/api-keys
RESEND_API_KEY=""

# === Sentry (Module 17) ===============================================
PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
